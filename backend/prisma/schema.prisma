// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum OrderStatus {
  PENDING
  ACCEPTED
  DELIVERED
}

enum PaymentMode {
  CASH
  CREDIT
}

enum UserRole {
  DISTRIBUTOR
  SHOPKEEPER
  SUPERADMIN
}

model User {
  id          String       @id @default(uuid())
  email       String       @unique
  password    String
  role        UserRole
  distributor Distributor?
  shopkeeper  Shopkeeper?
}

model Distributor {
  id              String                  @id @default(uuid())
  userId          String                  @unique
  user            User                    @relation(fields: [userId], references: [id])
  distributorName String                  @db.VarChar(20)
  products        Product[]
  shopkeeper      DistributorShopkeeper[]
  orders          Order[]
  payments        Payment[]
}

model Shopkeeper {
  id                   String                  @id @default(uuid())
  userId               String                  @unique
  user                 User                    @relation(fields: [userId], references: [id])
  shopName             String                  @db.VarChar(20)
  mobileNumber         Int
  shopAddress          String
  shopPhoto            String
  creditLimit          Int                     @default(100000)
  currentPaymentAmount Int
  distributors         DistributorShopkeeper[]
  orders               Order[]
  payments             Payment[]

  @@unique([shopName, mobileNumber])
}

model DistributorShopkeeper {
  id            String      @id @default(uuid())
  distributorId String
  shopkeeperId  String
  distributor   Distributor @relation(fields: [distributorId], references: [id])
  shopkeeper    Shopkeeper  @relation(fields: [shopkeeperId], references: [id])
}

model Product {
  id            String      @id @default(uuid())
  name          String
  price         Int
  category      String
  distributorId String
  distributor   Distributor @relation(fields: [distributorId], references: [id])
  image         String
  isNewArrival  Boolean
  orders        Order[]
}

model Order {
  id            String      @id @default(uuid())
  productId     String
  product       Product     @relation(fields: [productId], references: [id])
  shopkeeperId  String
  distributorId String
  shopkeeper    Shopkeeper  @relation(fields: [shopkeeperId], references: [id])
  distributor   Distributor @relation(fields: [distributorId], references: [id])
  orderQuantity Int
  orderPrice    Int
  orderStatus   OrderStatus @default(PENDING)
}

model Payment {
  id                String      @id @default(uuid())
  amount            Int
  mode              PaymentMode
  outstandingAmount Int
  shopkeeperId      String
  distributorId     String
  shopkeeper        Shopkeeper  @relation(fields: [shopkeeperId], references: [id])
  distributor       Distributor @relation(fields: [distributorId], references: [id])
}
